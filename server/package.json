{
  "name": "healthai-server",
  "version": "1.0.0",
  "description": "HealthAI Backend — Smart Medical Symptom Assistant (Google Antigravity Hackathon)",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "keywords": ["healthai", "gemini", "healthcare", "symptom-analysis"],
  "author": "raunakiitp",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testPathIgnorePatterns": ["/node_modules/"],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js"
    ]
  }
}
